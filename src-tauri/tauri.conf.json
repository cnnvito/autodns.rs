{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "autodns",
  "version": "0.2.0",
  "identifier": "com.autodns.desktop",
  "build": {
    "beforeDevCommand": "cd frontend && npm run dev",
    "beforeBuildCommand": "cd frontend && npm run build",
    "devUrl": "http://127.0.0.1:5173",
    "frontendDist": "../frontend/dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "autodns",
        "width": 1120,
        "height": 760,
        "visible": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["app", "dmg"],
    "icon": [
      "icons/icon.icns",
      "icons/appicon.ico",
      "icons/appicon.png"
    ]
  }
}
